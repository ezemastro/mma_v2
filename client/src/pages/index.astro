---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import Header from "../components/sections/Header.astro";
import Cards from "../components/sections/Cards.astro";
import Stats from "../components/sections/Stats.astro";
import Clients from "../components/sections/Clients.astro";
import Layout from "../layouts/Layout.astro";
import Text from "../components/sections/Text.astro";

const reader = createReader(process.cwd(), keystaticConfig);

const homeData = await reader.singletons.homepage.read();

if (!homeData) return Astro.redirect("/404");
---

<Layout title={homeData.header.title}>
  <Header content={homeData.header} />

  {
    homeData.sections.map((section) => {
      switch (section.discriminant) {
        case "cards":
          return <Cards {...section.value} />;
        case "stats":
          return <Stats {...section.value} />;
        case "clients":
          return <Clients {...section.value} />;
        case "text":
          return <Text {...section.value} />;
        default:
          return null;
      }
    })
  }
</Layout>
