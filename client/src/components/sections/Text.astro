---
import Section from "../common/Section.astro";
import type { Entry } from "@keystatic/core/reader";
import keystaticConfig from "../../../keystatic.config";
import MarkdocRender from "../common/MarkdocRender.astro";

type HomepageEntry = Entry<(typeof keystaticConfig)["singletons"]["homepage"]>;

type Props = Extract<
  HomepageEntry["sections"][number],
  { discriminant: "text" }
>["value"] & {
  isFirst?: boolean;
};

const { content, image, link, title, subtitle, isFirst } = Astro.props;
---

<Section title={title} subtitle={subtitle} link={link} isFirst={isFirst}>
  {
    image ? (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center max-w-4xl mx-auto">
        <img src={image} alt={title} class="w-full h-auto" />
        <MarkdocRender content={content} />
      </div>
    ) : (
      <div class="max-w-4xl mx-auto text-center">
        <MarkdocRender content={content} />
      </div>
    )
  }
</Section>
